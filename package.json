{
  "name": "@resultkitchen/reframe",
  "version": "0.4.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/resultkitchen/reframe.git"
  },
  "homepage": "https://github.com/resultkitchen/reframe#readme",
  "bugs": {
    "url": "https://github.com/resultkitchen/reframe/issues"
  },
  "keywords": [
    "code-review",
    "audit",
    "playwright",
    "llm",
    "agents",
    "gemini",
    "claude",
    "openai",
    "ux",
    "compliance",
    "accessibility"
  ],
  "description": "Reframe — point it at any repo, get back a verified, human-reviewed Pull Request. Screen-by-screen audit + fix engine.",
  "bin": {
    "reframe": "dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist/",
    "config/*.template.json",
    "config/models.json",
    "tests/fixtures/**",
    "docs/**",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "reframe": "tsx src/cli.ts",
    "test": "node --import tsx --test src/test/*.test.ts",
    "check-fixtures": "tsx tests/fixtures/validate.ts",
    "eval": "tsx tests/eval/run.ts",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "playwright": "^1.50.0",
    "simple-git": "^3.27.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
