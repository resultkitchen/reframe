{
  "name": "rebuild-pipeline",
  "version": "0.1.0",
  "private": true,
  "description": "Portable SaaS rebuild pipeline — 1 mapper + 6-agent per-page fan-out, Gemini-driven.",
  "bin": {
    "pipeline": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "pipeline": "tsx src/cli.ts",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@google/genai": "^1.40.0",
    "playwright": "^1.50.0",
    "simple-git": "^3.27.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
